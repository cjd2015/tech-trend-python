# Crucix Python - Environment Variables

# === FREE API KEYS (Recommended) ===

# FRED - Federal Reserve Economic Data
FRED_API_KEY=abcdefghijklmnopqrstuvwxyz123456

# EIA - US Energy Information Administration  
EIA_API_KEY=

# NASA FIRMS - Satellite fire detection
FIRMS_MAP_KEY=

# === OPTIONAL API KEYS ===

# ACLED - Armed Conflict Data
ACLED_EMAIL=
ACLED_PASSWORD=

# AISStream - Vessel tracking
AISSTREAM_API_KEY=

# ADS-B Exchange - Flight tracking
ADSB_API_KEY=

# BLS - Bureau of Labor Statistics
BLS_API_KEY=

# Cloudflare Radar
CLOUDFLARE_API_TOKEN=

# Reddit OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ReliefWeb
RELIEFWEB_APPNAME=

# === LLM PROVIDER (Optional) ===
LLM_PROVIDER=anthropic  # anthropic, openai, gemini
LLM_API_KEY=
LLM_MODEL=

# === ALERTS (Optional) ===

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_WEBHOOK_URL=

# === SERVER CONFIG ===
PORT=3117
REFRESH_INTERVAL_MINUTES=15
